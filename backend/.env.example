# =============================================
# FACEBOOK APP CONFIGURATION
# Tạo app tại: https://developers.facebook.com
# =============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# URL callback phải khớp với Facebook App settings
# Development: http://localhost:5000/auth/facebook/callback
FACEBOOK_CALLBACK_URL=http://localhost:5000/auth/facebook/callback

# =============================================
# SESSION
# =============================================
SESSION_SECRET=your_super_secret_session_key_change_this

# =============================================
# SERVER
# =============================================
PORT=5000
NODE_ENV=development

# URL frontend (để redirect sau login)
FRONTEND_URL=http://localhost:5173

# =============================================
# AI SERVICE (Python FastAPI)
# Docker: http://ai-service:8000
# Local:  http://localhost:8000
# =============================================
AI_SERVICE_URL=http://localhost:8000

# =============================================
# DATABASE (PostgreSQL + pgvector)
# Docker: tự động set qua docker-compose
# Local (no docker): điền connection string bên dưới
# =============================================
DATABASE_URL=postgresql://fbadmin:fbpassword@localhost:5432/fbpagemanager

# =============================================
# REDIS (BullMQ queues)
# Docker: tự động set qua docker-compose
# Local: redis://localhost:6379
# =============================================
REDIS_URL=redis://localhost:6379

# =============================================
# FACEBOOK WEBHOOK (optional)
# Cấu hình tại: Facebook App > Webhooks
# Callback URL: https://your-domain.com/sync/webhook
# =============================================
FB_WEBHOOK_VERIFY_TOKEN=your_random_secret_string

# =============================================
# CHAT WEBHOOK
# Callback URL: https://your-domain.com/webhook/chat
# Subscribed fields: messages
# =============================================
CHAT_WEBHOOK_VERIFY_TOKEN=your_chat_webhook_verify_token
