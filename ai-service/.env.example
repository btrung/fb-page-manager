# =============================================
# GOOGLE GEMINI — thay thế OpenAI, có free tier
# Lấy API key tại: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM (LLM), 1500 req/ngày (embedding)
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here

# Model dùng cho LLM extraction + vision
# gemini-1.5-flash: free, nhanh, hỗ trợ ảnh
VISION_MODEL=gemini-1.5-flash

# Model dùng cho text embedding (768 dimensions)
EMBEDDING_MODEL=models/text-embedding-004

# =============================================
# QDRANT — vector database
# Docker: http://qdrant:6333
# Local:  http://localhost:6333
# =============================================
QDRANT_URL=http://localhost:6333

# =============================================
# SERVER
# =============================================
PORT=8000
HOST=0.0.0.0
